{
  "name": "text-giveaway-bot",
  "version": "1.0.0",
  "description": "Telegram giveaway bot with scheduled channel posts",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "support": "node src/support-bot.js",
    "depman-support": "node src/depman-support-bot.js",
    "dev": "node --watch src/index.js",
    "dev:design": "node --env-file=.env --env-file=.env.design src/index.js",
    "reset-brand-profiles": "node scripts/reset-brand-project-profiles.js",
    "migrate:sqlite": "node scripts/migrate-json-to-sqlite.js --apply",
    "migrate:sqlite:dry": "node scripts/migrate-json-to-sqlite.js",
    "backup:data": "bash scripts/backup-data.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "telegraf": "^4.16.3"
  }
}
