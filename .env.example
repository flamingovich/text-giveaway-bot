BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789
SUPER_ADMIN_IDS=123456789
TIMEZONE=Europe/Moscow
CHECK_INTERVAL_MS=30000
WEB_PORT=30009
WEB_PUBLIC_URL=https://rollerbot.pro
# Панель организатора: {WEB_PUBLIC_URL}/panel
# Mini App участия (URL в BotFather): {WEB_PUBLIC_URL}/join/app
JOIN_MINI_APP_SHORT_NAME=join
# Mini App итогов (URL в BotFather, Direct Link): {WEB_PUBLIC_URL}/winners/app
WINNERS_MINI_APP_SHORT_NAME=winners
WEB_AUTH_DISABLED=false
WEB_ONLY=false
# Резервный курс ₽ за 1 USD/USDT, если все API недоступны
RUB_TO_USDT_RATE=71.02
BOT_USERNAME=your_bot_username_without_at

# Support bot (@rollerbot_support_bot) — отдельный процесс: npm run support
SUPPORT_BOT_TOKEN=your_support_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Эскалации на живого оператора (если пусто — берётся ADMIN_IDS)
# SUPPORT_ADMIN_IDS=123456789
SUPPORT_HOURS_START=9
SUPPORT_HOURS_END=21
SUPPORT_OPERATOR_SEARCH_MIN_MS=5000
SUPPORT_OPERATOR_SEARCH_MAX_MS=20000
SUPPORT_TYPING_START_MIN_MS=2000
SUPPORT_TYPING_START_MAX_MS=4000
SUPPORT_REPLY_DELAY_MIN_MS=15000
SUPPORT_REPLY_DELAY_MAX_MS=35000

# Admin dashboard: {WEB_PUBLIC_URL}/admin/dashboard
ADMIN_DASHBOARD_LOGIN=admin
ADMIN_DASHBOARD_PASSWORD=change_me
